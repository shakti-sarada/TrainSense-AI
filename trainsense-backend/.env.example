# ==========================
# Application
# ==========================
APP_NAME=TrainSense AI
APP_VERSION=1.0.0
DEBUG=False

# ==========================
# Server
# ==========================
HOST=0.0.0.0
PORT=8000

# ==========================
# Groq
# ==========================
GROQ_API_KEY=your_groq_api_key

# ==========================
# Railway APIs
# ==========================
ERAIL_API_KEY=your_erail_api_key
INDIANRAIL_API_KEY=your_indianrail_api_key

# ==========================
# Neon PostgreSQL
# ==========================
NEON_DSN=postgresql://username:password@host/database

# ==========================
# Cache
# ==========================
CACHE_ENABLED=True
CACHE_DEFAULT_TTL=300

# ==========================
# Session
# ==========================
SESSION_TIMEOUT_MINUTES=30

# ==========================
# Logging
# ==========================
LOG_LEVEL=INFO